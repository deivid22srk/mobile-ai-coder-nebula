{
  "name": "mobile-code-agent",
  "version": "1.0.0",
  "description": "Mobile Code Agent inspired by Claude Code and OpenCode",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "esbuild src/main.ts --bundle --outfile=public/bundle.js --minify --sourcemap",
    "watch": "esbuild src/main.ts --bundle --outfile=public/bundle.js --watch",
    "tui": "node tui.js"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "highlight.js": "^11.11.1",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
