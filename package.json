{
  "name": "mobile-code-agent",
  "version": "1.0.0",
  "description": "Mobile Code Agent inspired by Claude Code and OpenCode",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:web": "cd web-ui && npx vite --host 0.0.0.0 --port 5173",
    "predev": "node scripts/ensure-web-deps.js",
    "dev": "concurrently -n backend,web -c magenta,cyan \"npm:start\" \"npm:start:web\"",
    "postinstall": "node scripts/ensure-web-deps.js",
    "build": "esbuild src/main.ts --bundle --outfile=public/bundle.js --minify --sourcemap",
    "build:web": "cd web-ui && npx vite build",
    "watch": "esbuild src/main.ts --bundle --outfile=public/bundle.js --watch",
    "tui": "node tui.js"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "highlight.js": "^11.11.1",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
